# ─── App ───────────────────────────────────────────
APP_NAME=BarberPro
ENVIRONMENT=development
DEBUG=true

# ─── PostgreSQL ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://barberpro:changeme@localhost:5432/barberpro

# ─── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───────────────────────────────────────────
JWT_SECRET_KEY=generate-a-strong-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440  # 24hs

# ─── Admin ─────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ─── n8n ───────────────────────────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/barberpro

# ─── CORS ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Tests ─────────────────────────────────────────
TEST_DATABASE_URL=sqlite+aiosqlite:///./test.db
